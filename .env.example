# Matcha AI - Environment Configuration Reference
# Copy relevant sections to .env files in each service directory

# ============================================================================
# ORCHESTRATOR SERVICE (services/orchestrator/.env)
# ============================================================================
DATABASE_URL="postgresql://matcha_user:matcha_password@localhost:5433/matcha_db?schema=public"
HF_TOKEN=your_huggingface_token_here
CORS_ORIGIN=http://localhost:3001
INFERENCE_URL=http://localhost:8000
PORT=4000
JWT_SECRET=matcha_jwt_secret_key_change_in_production
REDIS_HOST=localhost
REDIS_PORT=6380

# ============================================================================
# INFERENCE SERVICE (services/inference/.env)
# ============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
HF_TOKEN=your_huggingface_token_here
ORCHESTRATOR_URL=http://localhost:4000/api/v1

# ============================================================================
# WEB FRONTEND (apps/web/.env.local)
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:4000/api/v1

# ============================================================================
# MOBILE APP (apps/mobile/app.config.ts)
# Configured via app.config.ts, uses same API_URL as web frontend
# ============================================================================
# API_URL=http://localhost:4000/api/v1

# ============================================================================
# SERVICE CONNECTIVITY MAP
# ============================================================================
# Web Frontend (3001) → Orchestrator API (4000)
# Orchestrator (4000) → Inference Service (8000)
# Orchestrator (4000) → PostgreSQL (5433)
# Orchestrator (4000) → Redis (6380)
# Inference (8000) → Orchestrator API (4000) [for event/progress callbacks]
# All services → PostgreSQL, Redis, MinIO (Docker containers)

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL credentials (from docker-compose.yml):
# - Host: localhost
# - Port: 5433
# - Database: matcha_db
# - User: matcha_user
# - Password: matcha_password
# - Connection string uses schema=public

# ============================================================================
# EXTERNAL API KEYS
# ============================================================================
# GEMINI_API_KEY: Google Gemini API for natural language analysis
# HF_TOKEN: Hugging Face token for model access (optional)
# Note: Keep API keys confidential; use appropriate secrets management in production
